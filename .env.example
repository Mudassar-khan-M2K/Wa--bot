# ─────────────────────────────────────────────
#  WhatsApp Downloader Bot — Environment Config
# ─────────────────────────────────────────────

# Your WhatsApp number with country code (no + or spaces)
# Example: 923001234567
PHONE_NUMBER=923001234567

# Bot display name
BOT_NAME=DL-Bot

# Command prefix (. or ! or /)
PREFIX=.

# Owner number (same as PHONE_NUMBER usually)
OWNER_NUMBER=923001234567

# Bot mode: public (anyone can use) | private (owner only)
MODE=public

# Session folder name
SESSION_NAME=session

# Max file size to send via WhatsApp in MB (WhatsApp limit is ~64 MB)
MAX_FILE_SIZE_MB=50

# Auto-delete downloaded temp files after sending (true/false)
AUTO_CLEANUP=true

# Show typing indicator while processing (true/false)
AUTO_TYPING=true
